---
import { BOOKING_URL } from "../lib/constants";
---

<footer class="pt-20 md:pt-28 pb-32 border-t border-rule">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-display text-2xl md:text-3xl leading-snug mb-10 max-w-3xl">
      You've tried. It hasn't worked yet.
      I'm the person who makes it work.
    </p>

    <div class="flex flex-wrap gap-6">
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-sm text-accent hover:text-accent-hover transition-colors"
        data-ph-capture="cta_book_consultation"
        data-ph-section="footer"
      >
        Book a conversation &rarr;
      </a>
      <a
        href="/newsletter"
        class="font-mono text-sm text-text-muted hover:text-text transition-colors"
        data-ph-capture="cta_newsletter"
        data-ph-section="footer"
      >
        Read the newsletter &rarr;
      </a>
    </div>

    <p class="mt-16 font-mono text-xs text-text-muted">
      &copy; 2026 Saadiq Rodgers-King
    </p>
  </div>
</footer>
