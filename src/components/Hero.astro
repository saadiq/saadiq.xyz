---
import { BOOKING_URL } from "../lib/constants";
---

<section class="pt-40 md:pt-48 pb-20 md:pb-28">
  <div class="max-w-5xl mx-auto px-6">
    <p class="section-label mb-8">// ai transformation</p>
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl leading-tight mb-6">
      Smart leaders are stuck on AI. I get their teams unstuck.<span class="cursor-blink text-accent">_</span>
    </h1>
    <p class="text-lg md:text-xl text-text-muted max-w-2xl mb-10 leading-relaxed">
      You've purchased the licenses. You've made the proclamations. You may even have an internal champion. Nothing has changed. I take a hands-on approach to showing your team what's possible and how.
    </p>
    <a
      href={BOOKING_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-accent hover:text-accent-hover font-mono transition-colors"
      data-ph-capture="cta_book_consultation"
      data-ph-section="hero"
    >
      Book a conversation &rarr;
    </a>
  </div>
</section>
